# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT-8000

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tailorstaq
DB_USER=tailorstaq_user
DB_PASSWORD=nedee123
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRY_SECONDS=86400

# ─────────────────────────────────────────────
# Bcrypt
# ─────────────────────────────────────────────
BCRYPT_COST_FACTOR=12

# ─────────────────────────────────────────────
# Object Store (AWS S3 or compatible)
# ─────────────────────────────────────────────
OBJECT_STORE_PROVIDER=s3
OBJECT_STORE_BUCKET=tailorstaq-uploads
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY_ID=change_me
OBJECT_STORE_SECRET_ACCESS_KEY=change_me
OBJECT_STORE_ENDPOINT=
OBJECT_STORE_FORCE_PATH_STYLE=false

# ─────────────────────────────────────────────
# Email / SMTP (Nodemailer)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change_me
SMTP_PASSWORD=change_me
SMTP_FROM_NAME=TAILORSTAQ
SMTP_FROM_EMAIL=no-reply@tailorstaq.com

# ─────────────────────────────────────────────
# BullMQ queue names
# ─────────────────────────────────────────────
QUEUE_EMAIL=email
QUEUE_PDF=pdf-generation

# ─────────────────────────────────────────────
# Subscription limits (Free tier)
# ─────────────────────────────────────────────
FREE_TIER_MAX_PRODUCTS=10
FREE_TIER_MAX_MONTHLY_ORDERS=50

# ─────────────────────────────────────────────
# Account lockout
# ─────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ─────────────────────────────────────────────
# File upload limits
# ─────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_BYTES=5242880

# ─────────────────────────────────────────────
# Frontend URL (for email links)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
